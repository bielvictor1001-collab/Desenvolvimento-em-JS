let lista = [];
let opcao = "";

while (opcao !== "4") {

    opcao = prompt(
        "Escolha uma opção:\n" +
        "1 - Adicionar item\n" +
        "2 - Remover item\n" +
        "3 - Listar itens\n" +
        "4 - Sair"
    );

    if (opcao === "1") {
        let item = prompt("Digite o nome do item para adicionar:");
        lista.push(item);
        alert(" Item adicionado!");

    } else if (opcao === "2") {
        let itemRemover = prompt("Digite o nome do item para remover:");
        let encontrado = false;

        for (let i = 0; i < lista.length; i++) {
            if (lista[i] === itemRemover) {
                lista.splice(i, 1);
                encontrado = true;
                alert(" Item removido!");
                break;
            }
        }

        if (!encontrado) {
            alert(" Item não encontrado!");
        }

    } else if (opcao === "3") {

        if (lista.length === 0) {
            alert("📭 Lista vazia!");
        } else {
            let texto = " Sua lista de compras:\n";

            for (let i = 0; i < lista.length; i++) {
                texto += (i + 1) + " - " + lista[i] + "\n";
            }

            alert(texto);
        }

    } else if (opcao !== "4") {
        alert(" Opção inválida!");
    }
}

alert(" Programa encerrado!");







